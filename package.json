{
  "name": "wordpress-mcp-server",
  "version": "1.0.0",
  "description": "MCP Server für WordPress - Ermöglicht AI-basierte Bearbeitung von Elementor, Gutenberg und WordPress-Inhalten",
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "wp-mcp": "./dist/cli.js",
    "wordpress-mcp": "./dist/server.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "start:http": "MCP_TRANSPORT=http node dist/server.js",
    "dev": "tsx src/server.ts",
    "dev:http": "MCP_TRANSPORT=http tsx src/server.ts",
    "watch": "tsc --watch",
    "init": "node dist/cli.js init",
    "test:connection": "node dist/cli.js test",
    "info": "node dist/cli.js info",
    "vscode:config": "node dist/cli.js vscode"
  },
  "keywords": [
    "mcp",
    "wordpress",
    "elementor",
    "gutenberg",
    "ai",
    "vscode",
    "copilot"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.2",
    "dotenv": "^17.2.3",
    "express": "^4.18.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
