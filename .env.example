# WordPress MCP Server Konfiguration
# Kopiere diese Datei zu .env und fülle die Werte aus
#
# Schnellstart:
#   cp .env.example .env
#   nano .env  (oder: npm run init)
#   npm start

# ============================================
# WORDPRESS VERBINDUNG (ERFORDERLICH)
# ============================================

# WordPress Site URL (ohne trailing slash)
WORDPRESS_SITE_URL=https://deine-website.de

# WordPress Benutzername
WORDPRESS_USERNAME=admin

# WordPress Application Password
# Erstelle unter: WordPress Admin → Benutzer → Profil → Anwendungs-Passwörter
WORDPRESS_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# ============================================
# AUTHENTIFIZIERUNG (OPTIONAL)
# ============================================

# Authentifizierungsmodus: basic (Standard) oder jwt
WORDPRESS_AUTH_MODE=basic

# JWT Token (nur wenn WORDPRESS_AUTH_MODE=jwt)
# WORDPRESS_JWT_TOKEN=eyJ0eXAiOiJKV1QiLCJhbGc...

# ============================================
# SERVER EINSTELLUNGEN (OPTIONAL)
# ============================================

# HTTP Server Port (für VS Code direkte Verbindung)
MCP_HTTP_PORT=3000

# REST API Basis-Pfad (Standard: /wp-json/wp/v2)
# WORDPRESS_REST_API_BASE=/wp-json/wp/v2
